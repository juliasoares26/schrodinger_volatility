# .gitignore

# ── Environment ────────────────────────────────────────────────────────
.env
*.env

# ── Data (never commit raw or processed data) ─────────────────────────
data/
results/

# ── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
notebooks/*.ipynb    # uncomment if you want to exclude notebooks too

# ── IDEs ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Test / coverage ────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
