# .env.example
# =============
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to git.

# ── Interactive Brokers ────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # paper trading TWS; live=7496; Gateway paper=4002
IBKR_CLIENT_ID=1

# ── CBOE DataShop (bulk historical option data) ───────────────────────
# Sign up at https://datashop.cboe.com/
CBOE_API_KEY=

# ── Optional: Polygon.io (real-time option data) ──────────────────────
POLYGON_API_KEY=
